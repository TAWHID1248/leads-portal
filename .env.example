# ----- Django core -----
SECRET_KEY=
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=

# ----- Database -----
# Local dev defaults to sqlite:///db.sqlite3 if blank.
DATABASE_URL=

# ----- Hosts (prod only) -----
# Comma-separated, e.g. portal.example.com,leads.example.com
ALLOWED_HOSTS=

# Comma-separated full origins, e.g. https://portal.example.com
CSRF_TRUSTED_ORIGINS=

# ----- Email (SendGrid SMTP) -----
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=

# ----- AWS / S3 (CSV exports + invoice PDFs) -----
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ----- Stripe -----
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Redis / Celery -----
# Railway auto-provides REDIS_URL once you add a Redis service.
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# In local dev, set ALWAYS_EAGER=true so tasks run inline without a worker.
CELERY_TASK_ALWAYS_EAGER=true

# ----- Super admin seed (used by: python manage.py seed) -----
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ----- Portal base URL (used in welcome / reset emails) -----
PORTAL_BASE_URL=
